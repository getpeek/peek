<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow app to receive Apple Events -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Allow DYLD environment variables (needed for some dependencies) -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Allow unsigned executable memory (needed for some JS engines) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow JIT compilation (needed for WebKit) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Disable library validation to allow loading of unsigned libraries -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Disable executable memory protection -->
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <true/>

    <!-- Allow debugging -->
    <key>com.apple.security.cs.debugger</key>
    <true/>

    <!-- Network client access -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Network server access (if your app needs to listen on ports) -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access permissions -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
